// Digital Dice Project

// LED pins
int ledPins[7] = {2, 3, 4, 5, 6, 7, 8};

// Button pin
int buttonPin = 9;

void setup() {
  // Set LED pins as OUTPUT
  for(int i = 0; i < 7; i++) {
    pinMode(ledPins[i], OUTPUT);
  }

  // Set button pin as INPUT with pull-up
  pinMode(buttonPin, INPUT_PULLUP);

  // Initialize random seed
  randomSeed(analogRead(0));
}

void loop() {

  // Check button press (LOW when pressed)
  if(digitalRead(buttonPin) == LOW) {

    int dice = random(1, 7); // Random number 1–6

    displayDice(dice);

    delay(500); // debounce delay
  }
}

// Function to display dice number
void displayDice(int num) {

  // Turn OFF all LEDs
  for(int i = 0; i < 7; i++) {
    digitalWrite(ledPins[i], LOW);
  }

  // Display patterns
  switch(num) {

    case 1:
      digitalWrite(ledPins[6], HIGH); // center
      break;

    case 2:
      digitalWrite(ledPins[0], HIGH);
      digitalWrite(ledPins[5], HIGH);
      break;

    case 3:
      digitalWrite(ledPins[0], HIGH);
      digitalWrite(ledPins[6], HIGH);
      digitalWrite(ledPins[5], HIGH);
      break;

    case 4:
      digitalWrite(ledPins[0], HIGH);
      digitalWrite(ledPins[1], HIGH);
      digitalWrite(ledPins[4], HIGH);
      digitalWrite(ledPins[5], HIGH);
      break;

    case 5:
      digitalWrite(ledPins[0], HIGH);
      digitalWrite(ledPins[1], HIGH);
      digitalWrite(ledPins[4], HIGH);
      digitalWrite(ledPins[5], HIGH);
      digitalWrite(ledPins[6], HIGH);
      break;

    case 6:
      digitalWrite(ledPins[0], HIGH);
      digitalWrite(ledPins[1], HIGH);
      digitalWrite(ledPins[2], HIGH);
      digitalWrite(ledPins[3], HIGH);
      digitalWrite(ledPins[4], HIGH);
      digitalWrite(ledPins[5], HIGH);
      break;
  }
}
